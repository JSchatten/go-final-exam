# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Config files
config.json
settings.json
*.env

# Editor/IDE
# .idea/
# .vscode/


# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
